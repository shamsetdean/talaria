{
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/prim(.*)", "destination": "/api/prim" }
  ]
}
